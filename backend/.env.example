NODE_ENV=production
PORT=5000
# Optional bind host. Set BACKEND_HOST=127.0.0.1 for local/preview when only a local proxy should reach the API.
# Leave empty for Docker/platform deployments unless the private bind host is known.
BACKEND_HOST=

# Public frontend origin allowed to call the API in production or split-origin previews.
# For same-origin Cloudflare Tunnel preview through Vite/Caddy, keep browser traffic on one hostname.
# Quick Tunnel URLs change after restart; update this exact origin if cross-origin API calls are used.
FRONTEND_URL=https://your-frontend.example.com

# MongoDB connection string.
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/agent-lottery

# Use a long random secret in production. Minimum recommended length: 32 chars.
JWT_SECRET=replace-this-with-a-long-random-secret-value

# Production hardening flags.
AUTO_SEED_ADMIN=false
AUTO_SEED_CATALOG=false
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_PASSWORD=
# Required behind HTTPS reverse proxies such as Cloudflare Tunnel, Render, or Caddy.
TRUST_PROXY=true
HEALTH_EXPOSE_DETAILS=false
LOG_FORMAT=combined
BACKUP_DIR=./backups
MANYCAI_FEED_BASE_URL=http://vip.manycai.com/K269c291856f58e

# Read-only lottery provider adapter. Mock is local/test/CI only and does not call external network.
LOTTERY_PROVIDER=mock
LOTTERY_API_BASE_URL=https://provider.example.invalid
LOTTERY_API_KEY=replace-with-secret-manager-value
LOTTERY_API_TIMEOUT_MS=5000

# Recommended for production web instances: keep disabled and use external cron POST /api/lottery/sync-latest/cron
AUTO_SYNC_RESULTS=false
RESULT_SYNC_INTERVAL_MS=300000
# Fetch only feeds whose scheduled draw time is in this window. Defaults: before=0, after=2 hours.
RESULT_SYNC_BEFORE_DRAW_WINDOW_MS=0
RESULT_SYNC_AFTER_DRAW_WINDOW_MS=7200000

# Background read-model snapshot refresh. Write paths still schedule targeted rebuilds.
READ_MODEL_SNAPSHOT_REFRESH_INTERVAL_MS=300000
READ_MODEL_SNAPSHOT_STARTUP_DELAY_MS=30000

# Shared secret for external cron POST /api/lottery/sync-latest/cron
# Send via X-Cron-Token or Authorization: Bearer <token>
CRON_SYNC_TOKEN=replace-with-a-long-random-secret
