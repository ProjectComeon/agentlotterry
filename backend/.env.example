NODE_ENV=production
PORT=5000

# Public frontend origin allowed to call the API in production.
FRONTEND_URL=https://your-frontend.example.com

# MongoDB connection string.
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/agent-lottery

# Use a long random secret in production. Minimum recommended length: 32 chars.
JWT_SECRET=replace-this-with-a-long-random-secret-value

# Production hardening flags.
AUTO_SEED_ADMIN=false
AUTO_SEED_CATALOG=false
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_PASSWORD=
TRUST_PROXY=true
HEALTH_EXPOSE_DETAILS=false
LOG_FORMAT=combined
BACKUP_DIR=./backups
MANYCAI_FEED_BASE_URL=http://vip.manycai.com/K269c291856f58e
# Recommended for production web instances: keep disabled and use external cron POST /api/lottery/sync-latest/cron
AUTO_SYNC_RESULTS=false
RESULT_SYNC_INTERVAL_MS=300000

# Background read-model snapshot refresh. Write paths still schedule targeted rebuilds.
READ_MODEL_SNAPSHOT_REFRESH_INTERVAL_MS=300000
READ_MODEL_SNAPSHOT_STARTUP_DELAY_MS=30000

# Shared secret for external cron POST /api/lottery/sync-latest/cron
# Send via X-Cron-Token or Authorization: Bearer <token>
CRON_SYNC_TOKEN=replace-with-a-long-random-secret
