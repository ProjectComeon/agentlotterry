# Production environment template.
# Copy to a real secret store or a local .env file on the server only.
# Do not commit filled values.

# Backend runtime
NODE_ENV=production
PORT=5000
# Optional bind host. Use 127.0.0.1 for local/preview behind a same-machine proxy.
# Leave empty for platforms or container topologies that provide their own private interface.
BACKEND_HOST=
TRUST_PROXY=true
FRONTEND_URL=https://app.example.com

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/agent-lottery

# Auth/session
# Use a strong random value, at least 32 characters. Do not reuse preview/dev values.
JWT_SECRET=replace-with-a-long-random-production-secret

# Production bootstrap safety
AUTO_SEED_ADMIN=false
AUTO_SEED_CATALOG=false
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_PASSWORD=

# Health/logging
HEALTH_EXPOSE_DETAILS=false
LOG_FORMAT=combined

# Backup and retention
BACKUP_DIR=/var/backups/agent-lottery
AUTO_RETENTION_CLEANUP=false
RETENTION_KEEP_PREVIOUS_MONTHS=1
RETENTION_CLEANUP_INTERVAL_MS=86400000
RETENTION_CLEANUP_STARTUP_DELAY_MS=120000

# Result sync
# Recommended production pattern: keep web instances from auto-syncing and call the cron endpoint externally.
AUTO_SYNC_RESULTS=false
CRON_SYNC_TOKEN=replace-with-a-long-random-production-cron-token
RESULT_SYNC_INTERVAL_MS=300000
RESULT_SYNC_STARTUP_DELAY_MS=60000
RESULT_SYNC_BEFORE_DRAW_WINDOW_MS=0
RESULT_SYNC_AFTER_DRAW_WINDOW_MS=7200000

# Read-only lottery provider adapter. Production must choose a provider explicitly; leave empty to make preflight fail until reviewed.
# For preview/validation only, override with LOTTERY_PROVIDER=mock. Mock does not sync, import, settle, or submit real bets.
LOTTERY_PROVIDER=
LOTTERY_API_BASE_URL=https://provider.example.invalid
LOTTERY_API_KEY=replace-with-secret-manager-value
LOTTERY_API_TIMEOUT_MS=5000
LOTTERY_REAL_NETWORK_ENABLED=false
# Read model refresh
READ_MODEL_SNAPSHOT_REFRESH_INTERVAL_MS=300000
READ_MODEL_SNAPSHOT_STARTUP_DELAY_MS=30000

# Frontend build
# Same-origin reverse proxy: leave empty so the browser calls /api on the same host.
# Split-origin deployment only: set to the exact backend origin, without /api.
VITE_API_URL=
