# Frontend environment example.
# Keep empty for same-origin /api through Vite dev proxy, Docker/Caddy, or the recommended Cloudflare Tunnel preview.
VITE_API_URL=

# Optional read cache TTL override in milliseconds.
VITE_API_READ_CACHE_MS=15000

# Split-origin preview only. Do not include /api because the client appends /api.
# VITE_API_URL=https://api-preview.example.com
