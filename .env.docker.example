# Copy this file to .env.docker and fill real secrets before deploy.

# Local default: http://localhost:8080
# Cloudflare Tunnel preview: after the public HTTPS URL is known, set PUBLIC_ORIGIN to that exact URL.
# Quick Tunnel URLs change after restart; Named Tunnel URLs can remain stable.
# Production with Caddy HTTPS: set APP_SITE_ADDRESS=your-domain.com and PUBLIC_ORIGIN=https://your-domain.com
APP_SITE_ADDRESS=:80
PUBLIC_ORIGIN=http://localhost:8080
HTTP_PORT=8080
HTTPS_PORT=8443

# Keep empty so frontend calls same-origin /api through Caddy.
VITE_API_URL=

NODE_ENV=production
PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/agent-lottery
JWT_SECRET=replace-this-with-a-long-random-secret-value

AUTO_SEED_ADMIN=false
AUTO_SEED_CATALOG=false
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_PASSWORD=
TRUST_PROXY=true
HEALTH_EXPOSE_DETAILS=false
LOG_FORMAT=combined
BACKUP_DIR=/app/backups

MANYCAI_FEED_BASE_URL=http://vip.manycai.com/K269c291856f58e
AUTO_SYNC_RESULTS=false
RESULT_SYNC_INTERVAL_MS=300000
RESULT_SYNC_BEFORE_DRAW_WINDOW_MS=0
RESULT_SYNC_AFTER_DRAW_WINDOW_MS=7200000

READ_MODEL_SNAPSHOT_REFRESH_INTERVAL_MS=300000
READ_MODEL_SNAPSHOT_STARTUP_DELAY_MS=30000

CRON_SYNC_TOKEN=replace-with-a-long-random-secret
